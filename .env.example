# ═══════════════════════════════════════════════
#  Ghost Tunnel — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── SSH Root Password ───────────────────────────
# REQUIRED: Password for SSH root login
ROOT_PASS=Kosay378%

# ── ntfy Notification Topic ─────────────────────
# REQUIRED: ntfy.sh topic for tunnel notifications
NTFY_TOPIC=temp-mail1

# ── Port List ───────────────────────────────────
# Comma-separated list of ports to expose via bore tunnel
# Examples:
#   Single port: PORTS=22
#   Multiple:    PORTS=22,80,443,3000,8080
PORTS=22

# ── Bore Server ─────────────────────────────────
# Bore server address (default: bore.pub)
BORE_SERVER=bore.pub

# ── HTTP Health Port ────────────────────────────
# Port for the internal health check HTTP server
# Railway/Render will set this automatically
PORT=8080

# ── Timezone ────────────────────────────────────
TZ=Asia/Jakarta

# ── Logging Level ───────────────────────────────
# Options: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
